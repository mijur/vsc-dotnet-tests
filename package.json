{
  "name": "dotnet-tests",
  "publisher": "local",
  "displayName": "Dotnet Tests",
  "description": "Visualize, run, and summarize .NET tests in VS Code.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Testing"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dotnetTestsContainer",
          "title": "Dotnet Tests",
          "icon": "media/beaker.svg"
        }
      ]
    },
    "views": {
      "dotnetTestsContainer": [
        {
          "id": "dotnetTestsView",
          "name": "Projects",
          "contextualTitle": "Dotnet Tests"
        }
      ]
    },
    "commands": [
      {
        "command": "dotnet-tests.actions",
        "title": "Actions",
        "category": "Dotnet Tests"
      },
      {
        "command": "dotnet-tests.refresh",
        "title": "Refresh",
        "category": "Dotnet Tests"
      },
      {
        "command": "dotnet-tests.runAll",
        "title": "Run All Tests",
        "category": "Dotnet Tests"
      },
      {
        "command": "dotnet-tests.showOutput",
        "title": "Show Output",
        "category": "Dotnet Tests"
      },
      {
        "command": "dotnet-tests.runNode",
        "title": "Run Selected Item",
        "category": "Dotnet Tests"
      },
      {
        "command": "dotnet-tests.revealInTestExplorer",
        "title": "Reveal in Test Explorer",
        "category": "Dotnet Tests"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dotnet-tests.refresh",
          "when": "view == dotnetTestsView",
          "group": "navigation@1"
        },
        {
          "command": "dotnet-tests.runAll",
          "when": "view == dotnetTestsView",
          "group": "navigation@2"
        },
        {
          "command": "dotnet-tests.actions",
          "when": "view == dotnetTestsView",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "dotnet-tests.runNode",
          "when": "view == dotnetTestsView && viewItem == dotnetTestNode",
          "group": "inline"
        },
        {
          "command": "dotnet-tests.revealInTestExplorer",
          "when": "view == dotnetTestsView && viewItem == dotnetTestNode",
          "group": "navigation"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "dotnetTestsView",
        "contents": "No .NET test projects found.\n[Refresh](command:dotnet-tests.refresh)",
        "when": "view == dotnetTestsView"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
