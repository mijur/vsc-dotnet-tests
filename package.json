{
  "name": "dotnet-tests",
  "publisher": "local",
  "displayName": "Dotnet Tests",
  "description": "Discover and run .NET tests in VS Code's built-in Testing view.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Testing"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dotnet-tests.actions",
        "title": "Show Actions",
        "category": "Dotnet Tests"
      },
      {
        "command": "dotnet-tests.openTestSource",
        "title": "Go to Test Source",
        "category": "Dotnet Tests"
      },
      {
        "command": "dotnet-tests.refresh",
        "title": "Refresh Discovered Tests",
        "category": "Dotnet Tests"
      },
      {
        "command": "dotnet-tests.runAll",
        "title": "Run All Tests",
        "category": "Dotnet Tests"
      },
      {
        "command": "dotnet-tests.showOutput",
        "title": "Show Output",
        "category": "Dotnet Tests"
      },
      {
        "command": "dotnet-tests.runNode",
        "title": "Run Test Target",
        "category": "Dotnet Tests"
      },
      {
        "command": "dotnet-tests.revealInTestExplorer",
        "title": "Reveal in Testing View",
        "category": "Dotnet Tests"
      }
    ],
    "menus": {
      "testing/item/context": [
        {
          "command": "dotnet-tests.openTestSource",
          "when": "controllerId == 'dotnet-tests.controller' && testId =~ /^(class|method):/ && testItemHasUri",
          "group": "navigation"
        }
      ],
      "testing/message/context": [
        {
          "command": "dotnet-tests.openTestSource",
          "when": "testMessage == 'dotnet-tests.source'",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
